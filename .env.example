# =============================================================================
# Nova Shop — NestJS Backend (.env.example)
# Copy to `.env` and fill in values. Never commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
# Comma-separated origins allowed for CORS (credentials/cookies).
# Include the Next.js storefront, admin panel, and any production domains.
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# -----------------------------------------------------------------------------
# Database — Supabase / PostgreSQL (required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host:5432/dbname

# -----------------------------------------------------------------------------
# JWT (required — must be distinct, random strings, 32+ characters each)
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars

# -----------------------------------------------------------------------------
# Google OAuth (required if using Google sign-in on storefront)
# GOOGLE_CLIENT_ID must match the value in Next.js `.env`
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Internal webhook (required for Stripe order confirmation from Next.js)
# Must match INTERNAL_WEBHOOK_SECRET in Nova-online-shopping-nextjs `.env`
# -----------------------------------------------------------------------------
INTERNAL_WEBHOOK_SECRET=change_me_internal_webhook_secret
